---
import { getContent } from '../../i18n/content';
import { getLangFromUrl } from '../../i18n/config';

const lang = getLangFromUrl(Astro.url);
const c = getContent(lang);
const roles = lang === 'es'
  ? ['DISEÑO', 'DESARROLLO', 'VISUALES', 'SONIDO']
  : ['DESIGN', 'DEVELOPMENT', 'VISUALS', 'SOUND'];
---

<section class="hero">
  <div class="container hero__top">
    <span class="label">{lang === 'es' ? 'ESTUDIO AUDIOVISUAL' : 'AUDIOVISUAL STUDIO'} — VALÈNCIA, ES</span>
    <span class="label label--accent">● {lang === 'es' ? 'DISPONIBLE PARA PROYECTOS' : 'AVAILABLE FOR WORK'}</span>
  </div>

  <div class="container hero__mid">
    <h1 class="hero__title">Dani<br />Zetta<span class="hero__cursor blink">_</span></h1>

    <div class="hero__meta">
      <ul class="hero__roles">
        {roles.map((r, i) => <li><span class="idx">0{i + 1}</span> {r}</li>)}
      </ul>
    </div>
  </div>

  <div class="container hero__bottom">
    <p class="hero__lead">{c.hero.subtitle}</p>
    <div class="hero__cta">
      <a class="btn btn--accent" href="#work">{c.hero.ctaWork} →</a>
      <a class="btn" href="#contact">{c.hero.ctaContact}</a>
    </div>
  </div>

  <div class="marquee" aria-hidden="true">
    <div class="marquee__track">
      <span>SELECTED WORK</span><span><b>↗</b></span><span>2024 — 2026</span><span><b>↗</b></span><span>DISEÑO · DESARROLLO · VISUALES · SONIDO</span><span><b>↗</b></span><span>VALÈNCIA → WORLDWIDE</span><span><b>↗</b></span>
      <span>SELECTED WORK</span><span><b>↗</b></span><span>2024 — 2026</span><span><b>↗</b></span><span>DISEÑO · DESARROLLO · VISUALES · SONIDO</span><span><b>↗</b></span><span>VALÈNCIA → WORLDWIDE</span><span><b>↗</b></span>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: 58px;
    display: flex;
    flex-direction: column;
    min-height: 100svh;
  }
  .hero__top {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    padding-block: 1rem;
    border-bottom: 1px solid var(--line);
  }
  .hero__mid {
    flex: 1;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    padding-block: clamp(1.5rem, 4vw, 3rem);
  }
  .hero__title {
    font-size: clamp(4.5rem, 21vw, 17rem);
    line-height: 0.82;
    letter-spacing: -0.04em;
    margin-left: -0.04em;
  }
  .hero__cursor { color: var(--accent); }
  .hero__roles {
    list-style: none;
    text-align: right;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .hero__roles li {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    color: var(--ink);
  }
  .hero__roles .idx { margin-right: 0.4ch; }
  .hero__bottom {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
    padding-bottom: clamp(2rem, 4vw, 3rem);
  }
  .hero__lead {
    max-width: 48ch;
    color: var(--muted);
    font-size: clamp(0.95rem, 1.3vw, 1.05rem);
  }
  .hero__cta { display: flex; gap: 0.75rem; flex-wrap: wrap; }

  @media (max-width: 760px) {
    .hero__mid { align-items: flex-start; flex-direction: column; }
    .hero__roles { text-align: left; flex-flow: row wrap; gap: 0.6rem 1.2rem; }
    .hero__title { font-size: clamp(4rem, 24vw, 9rem); }
  }
</style>

---
import { getContent } from '../../i18n/content';
import { getLangFromUrl } from '../../i18n/config';

const lang = getLangFromUrl(Astro.url);
const s = getContent(lang).services;
---

<section id="services" class="section services">
  <div class="container">
    <div class="section-head">
      <div>
        <span class="label">[03] {s.eyebrow}</span>
        <h2 class="section-title">{s.title}</h2>
      </div>
      <p class="section-lead">{s.subtitle}</p>
    </div>

    <div class="svc">
      {s.items.map((it, i) => (
        <article class="svc__item">
          <span class="svc__n">S{String(i + 1).padStart(2, '0')}</span>
          <h3 class="svc__title">{it.title}</h3>
          <p class="svc__desc">{it.desc}</p>
          <ul class="svc__tags">{it.tags.map((t) => <li>{t}</li>)}</ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .svc {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    border-top: 1px solid var(--line-strong);
    border-left: 1px solid var(--line-strong);
  }
  .svc__item {
    padding: clamp(1.5rem, 3vw, 2.5rem);
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    transition: background-color var(--t);
  }
  .svc__item:hover { background: var(--bg-2); }
  .svc__n {
    font-family: var(--font-mono);
    font-weight: 700;
    color: var(--accent);
    font-size: 0.8rem;
  }
  .svc__title {
    font-size: clamp(1.4rem, 3vw, 2.1rem);
    margin: 0.8rem 0 0.7rem;
  }
  .svc__desc { color: var(--muted); max-width: 46ch; }
  .svc__tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 1.2rem;
  }
  .svc__tags li {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border: 1px solid var(--line);
    padding: 0.3rem 0.6rem;
    color: var(--muted);
  }
  @media (max-width: 720px) {
    .svc { grid-template-columns: 1fr; }
  }
</style>

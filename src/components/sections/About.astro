---
import { getContent } from '../../i18n/content';
import { getLangFromUrl } from '../../i18n/config';

const lang = getLangFromUrl(Astro.url);
const c = getContent(lang);
---

<section id="about" class="section about">
  <div class="container">
    <div class="section-head">
      <span class="label">[04] {c.about.eyebrow}</span>
    </div>

    <div class="about__grid">
      <h2 class="about__title">{c.about.title}</h2>
      <div class="about__body">
        {c.about.body.map((p) => <p>{p}</p>)}
      </div>
    </div>

    <dl class="about__stats">
      {c.about.stats.map((s, i) => (
        <div class="stat">
          <dt class="stat__v">{s.value}</dt>
          <dd class="stat__l"><span class="idx">0{i + 1}</span> {s.label}</dd>
        </div>
      ))}
    </dl>
  </div>
</section>

<style>
  .about__grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: start;
  }
  .about__title {
    font-size: clamp(1.8rem, 4.5vw, 3.6rem);
    line-height: 1;
  }
  .about__body { display: flex; flex-direction: column; gap: 1rem; }
  .about__body p { color: var(--muted); }
  .about__stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    margin-top: clamp(2.5rem, 6vw, 4.5rem);
    border: 1px solid var(--line-strong);
  }
  .stat {
    padding: clamp(1.25rem, 3vw, 2rem);
    border-right: 1px solid var(--line);
  }
  .stat:last-child { border-right: 0; }
  .stat__v {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1;
    color: var(--accent);
  }
  .stat__l {
    margin-top: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--muted);
  }
  @media (max-width: 760px) {
    .about__grid { grid-template-columns: 1fr; gap: 1.5rem; }
    .about__stats { grid-template-columns: 1fr; }
    .stat { border-right: 0; border-bottom: 1px solid var(--line); }
    .stat:last-child { border-bottom: 0; }
  }
</style>

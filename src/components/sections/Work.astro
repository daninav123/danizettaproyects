---
import ProjectCard from '../ProjectCard.astro';
import { getProjects } from '../../data/projects';
import { getContent } from '../../i18n/content';
import { getLangFromUrl } from '../../i18n/config';

const lang = getLangFromUrl(Astro.url);
const c = getContent(lang);
const projects = getProjects();
---

<section id="work" class="section work">
  <div class="container">
    <header class="work__head" data-reveal>
      <p class="eyebrow">{c.work.eyebrow}</p>
      <h2 class="section-title">{c.work.title}</h2>
      <p class="section-lead">{c.work.subtitle}</p>
    </header>

    <div class="work__list">
      {projects.map((project, i) => (
        <ProjectCard project={project} lang={lang} index={i} />
      ))}
    </div>
  </div>
</section>

<style>
  .work__head {
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }
  .work__list {
    display: flex;
    flex-direction: column;
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }
</style>

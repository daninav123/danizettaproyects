---
import { getContent } from '../../i18n/content';
import { getLangFromUrl } from '../../i18n/config';

const lang = getLangFromUrl(Astro.url);
const c = getContent(lang);
---

<section id="contact" class="section contact">
  <div class="container">
    <div class="section-head">
      <span class="label">[05] {c.contact.eyebrow}</span>
    </div>

    <h2 class="contact__title">{c.contact.title}</h2>
    <p class="contact__lead">{c.contact.subtitle}</p>

    <a class="contact__mail" href={`mailto:${c.contact.email}`}>
      <span>{c.contact.email}</span>
      <span class="contact__arrow" aria-hidden="true">↗</span>
    </a>
  </div>
</section>

<style>
  .contact__title {
    font-size: clamp(2.6rem, 9vw, 7rem);
    line-height: 0.95;
    max-width: 16ch;
  }
  .contact__lead {
    margin-top: 1.25rem;
    max-width: 46ch;
    color: var(--muted);
  }
  .contact__mail {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: clamp(2rem, 5vw, 3.5rem);
    padding: clamp(1.1rem, 3vw, 1.8rem) clamp(1.1rem, 3vw, 1.8rem);
    border: 1px solid var(--ink);
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: clamp(1rem, 3vw, 1.8rem);
    letter-spacing: -0.01em;
    transition: background-color var(--t), color var(--t);
  }
  .contact__mail:hover { background: var(--accent); color: var(--accent-ink); }
  .contact__arrow { font-size: 1.2em; }
</style>

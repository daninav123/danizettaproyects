---
import { getContent } from '../i18n/content';
import { getLangFromUrl, localizedPath } from '../i18n/config';

const lang = getLangFromUrl(Astro.url);
const c = getContent(lang);

const path = Astro.url.pathname.replace(/^\/en/, '') || '/';
const otherLang = lang === 'es' ? 'en' : 'es';
const otherHref = localizedPath(path, otherLang);
const home = localizedPath('/', lang);

const links = [
  { href: '#work', label: c.nav.work, n: '01' },
  { href: '#visuals', label: c.nav.visuals, n: '02' },
  { href: '#about', label: c.nav.about, n: '03' },
  { href: '#contact', label: c.nav.contact, n: '04' },
];
---

<header class="hd" data-header>
  <div class="hd__bar container">
    <a class="hd__brand" href={home}>DANI ZETTA<sup>®</sup></a>

    <nav class="hd__nav" aria-label="Principal">
      {links.map((l) => (
        <a href={l.href}><span class="hd__n">{l.n}</span>{l.label}</a>
      ))}
    </nav>

    <div class="hd__right">
      <a class="hd__lang" href={otherHref} hreflang={otherLang}>
        <b class:list={[lang === 'es' && 'on']}>ES</b><span>/</span><b class:list={[lang === 'en' && 'on']}>EN</b>
      </a>
      <button class="hd__burger" data-burger aria-label="Menú" aria-expanded="false">MENU<span class="blink">_</span></button>
    </div>
  </div>

  <nav class="hd__mobile" data-mobile aria-label="Móvil">
    {links.map((l) => (
      <a href={l.href} data-mlink><span class="hd__n">{l.n}</span>{l.label}</a>
    ))}
    <a href={otherHref} data-mlink class="hd__mlang">{otherLang.toUpperCase()} ↗</a>
  </nav>
</header>

<script>
  const header = document.querySelector('[data-header]');
  const onScroll = () => header?.classList.toggle('is-scrolled', window.scrollY > 8);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
  const burger = document.querySelector('[data-burger]');
  const toggle = (open?: boolean) => {
    const isOpen = open ?? !header?.classList.contains('nav-open');
    header?.classList.toggle('nav-open', isOpen);
    burger?.setAttribute('aria-expanded', String(isOpen));
  };
  burger?.addEventListener('click', () => toggle());
  document.querySelectorAll('[data-mlink]').forEach((l) => l.addEventListener('click', () => toggle(false)));
</script>

<style>
  .hd {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 100;
    background: var(--bg);
    border-bottom: 1px solid var(--line);
    transition: border-color var(--t);
  }
  .hd.is-scrolled { border-bottom-color: var(--line-strong); }
  .hd__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    height: 58px;
  }
  .hd__brand {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.05rem;
    letter-spacing: -0.01em;
    text-transform: uppercase;
  }
  .hd__brand sup { color: var(--accent); font-size: 0.6em; }
  .hd__nav {
    display: flex;
    gap: 1.6rem;
  }
  .hd__nav a {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
    transition: color var(--t);
    display: inline-flex;
    align-items: baseline;
    gap: 0.45ch;
  }
  .hd__n { color: var(--accent); font-size: 0.66rem; }
  .hd__nav a:hover { color: var(--ink); }
  .hd__right { display: flex; align-items: center; gap: 1.1rem; }
  .hd__lang {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--dim);
    display: inline-flex;
    gap: 0.35ch;
  }
  .hd__lang b { color: var(--dim); font-weight: 700; }
  .hd__lang b.on { color: var(--ink); }
  .hd__burger {
    display: none;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    color: var(--ink);
    background: none;
    border: 0;
    cursor: pointer;
  }
  .hd__mobile { display: none; }

  @media (max-width: 800px) {
    .hd__nav { display: none; }
    .hd__burger { display: inline-block; }
    .hd__mobile {
      display: flex;
      flex-direction: column;
      border-top: 1px solid var(--line);
      max-height: 0;
      overflow: hidden;
      transition: max-height var(--t);
    }
    .hd.nav-open .hd__mobile { max-height: 80vh; }
    .hd__mobile a {
      font-family: var(--font-display);
      text-transform: uppercase;
      font-size: 2rem;
      padding: 0.7rem var(--gutter);
      border-bottom: 1px solid var(--line);
      display: flex;
      gap: 0.6ch;
      align-items: baseline;
    }
    .hd__mobile .hd__n { font-size: 0.9rem; }
    .hd__mlang { color: var(--accent) !important; }
  }
</style>

---
import { getContent } from '../i18n/content';
import { getLangFromUrl } from '../i18n/config';

const lang = getLangFromUrl(Astro.url);
const c = getContent(lang);
const year = 2026;

const socials = [
  { label: 'Email ↗', href: `mailto:${c.contact.email}` },
  { label: 'Instagram ↗', href: 'https://instagram.com/' },
  { label: 'LinkedIn ↗', href: 'https://linkedin.com/' },
];
---

<footer class="ft">
  <div class="ft__big container">DANI ZETTA<sup>®</sup></div>

  <div class="ft__grid container">
    <div class="ft__col">
      <span class="ft__h">{c.footer.tagline}</span>
    </div>
    <nav class="ft__col" aria-label={c.nav.work}>
      <span class="ft__h">{c.nav.work}</span>
      <a href="#work">{c.nav.work}</a>
      <a href="#visuals">{c.nav.visuals}</a>
      <a href="#about">{c.nav.about}</a>
    </nav>
    <nav class="ft__col" aria-label="Social">
      <span class="ft__h">{c.nav.contact}</span>
      {socials.map((s) => (
        <a href={s.href} target={s.href.startsWith('http') ? '_blank' : undefined} rel="noopener">{s.label}</a>
      ))}
    </nav>
  </div>

  <div class="ft__bottom container">
    <span>© {year} DANI ZETTA — {c.footer.rights}</span>
    <span>{c.footer.built}</span>
  </div>
</footer>

<style>
  .ft { border-top: 1px solid var(--line-strong); }
  .ft__big {
    font-family: var(--font-display);
    text-transform: uppercase;
    font-weight: 700;
    font-size: clamp(3rem, 16vw, 13rem);
    line-height: 0.85;
    letter-spacing: -0.04em;
    padding-block: clamp(1.5rem, 4vw, 3rem) clamp(1rem, 2vw, 1.5rem);
  }
  .ft__big sup { color: var(--accent); font-size: 0.4em; vertical-align: super; }
  .ft__grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 1.5rem;
    padding-block: 2rem;
    border-top: 1px solid var(--line);
  }
  .ft__col { display: flex; flex-direction: column; gap: 0.55rem; }
  .ft__h {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--dim);
    margin-bottom: 0.3rem;
  }
  .ft__col a {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--muted);
    width: fit-content;
    transition: color var(--t);
  }
  .ft__col a:hover { color: var(--accent); }
  .ft__bottom {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    padding-block: 1.25rem;
    border-top: 1px solid var(--line);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--dim);
  }
  @media (max-width: 700px) {
    .ft__grid { grid-template-columns: 1fr 1fr; }
    .ft__col:first-child { grid-column: 1 / -1; }
  }
</style>
